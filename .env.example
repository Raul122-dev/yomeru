# yomeru — copy to .env, or just leave as-is
# everything can also be configured from the Settings page

# port (default 7788)
# PORT=7788

# data directory — runs, config, uploads
# default: ~/.yomeru
# YOMERU_DATA=/custom/path

# ollama host — if running on a different machine
# WSL + Ollama on Windows: use the Windows IP
# OLLAMA_HOST=http://172.x.x.x:11434
